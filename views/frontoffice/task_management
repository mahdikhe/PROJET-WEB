        /* Modern Variables */
:root {
    --primary-color: #4361ee;
    --secondary-color: #3f37c9;
    --success-color: #4CAF50;
    --text-color: #2b2d42;
    --background-light: #f8f9fa;
    --transition-speed: 0.3s;
    --border-radius: 12px;
}

/* Animated Dashboard Layout */
.task-dashboard {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
}

/* Header Animations */
.task-header {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    transition: all var(--transition-speed);
    transform-origin: top;
}

.task-header:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(67, 97, 238, 0.2);
}

/* Sidebar Animations */
.task-sidebar, .task-sidebar-right {
    backdrop-filter: blur(10px);
    background: rgba(255, 255, 255, 0.9);
    transition: all var(--transition-speed);
}

.task-sidebar:hover, .task-sidebar-right:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
}

/* Progress Widget Animation */
.circular-progress {
    position: relative;
    transition: all 0.8s ease;
    transform: rotate(-90deg);
}

.circular-progress::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: conic-gradient(
        var(--primary-color) calc(var(--progress) * 1%),
        #e9ecef 0deg
    );
    mask: radial-gradient(white 55%, transparent 0);
    -webkit-mask: radial-gradient(white 55%, transparent 0);
}

/* Tab Animations */
.task-tabs {
    display: flex;
    gap: 10px;
    padding: 15px 0;
}

.tab-btn {
    position: relative;
    border: none;
    background: transparent;
    padding: 10px 20px;
    cursor: pointer;
    transition: all var(--transition-speed);
    overflow: hidden;
}

.tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--primary-color);
    transition: all var(--transition-speed);
}

.tab-btn.active::after {
    left: 0;
    width: 100%;
}

/* Content Transitions */
.tab-content {
    opacity: 0;
    transform: translateX(20px);
    transition: all var(--transition-speed);
    position: absolute;
}

.tab-content.active {
    opacity: 1;
    transform: translateX(0);
    position: relative;
}

/* Card Hover Effects */
.task-card {
    background: white;
    border-radius: var(--border-radius);
    padding: 20px;
    transition: all var(--transition-speed);
    cursor: pointer;
}

.task-card:hover {
    transform: translateY(-5px) rotate(1deg);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

/* Animations Keyframes */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

/* File Upload Zone Animation */
.file-upload-zone {
    border: 2px dashed #ccc;
    border-radius: var(--border-radius);
    padding: 40px;
    text-align: center;
    transition: all var(--transition-speed);
}

.file-upload-zone.drag-over {
    border-color: var(--primary-color);
    background: rgba(67, 97, 238, 0.05);
    transform: scale(1.02);
}
